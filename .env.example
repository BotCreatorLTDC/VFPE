# ─── VFPE Ecosystem — Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values

# ── MAIN BOT ──
MAIN_BOT_TOKEN=your_main_bot_token_here

# ── MODERATOR BOT ──
MODERATOR_BOT_TOKEN=your_moderator_bot_token_here

# ── CATALOG BOT (HashANDCrafts Catalog Service) ──
# Create a new bot with @BotFather → /newbot → name: HashANDCrafts_catalog_bot
CATALOG_BOT_TOKEN=your_catalog_bot_token_here

# ── DATABASE ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── WEB APP ──
PORT=3000
WEBAPP_URL=https://vfpe.onrender.com

# ── ADMIN ──
ADMIN_IDS=123456789,987654321

# ── TELEGRAM CHANNEL (for broadcasts) ──
CHANNEL_ID=-100xxxxxxxxxx
